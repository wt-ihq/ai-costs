# Copy to .env.local for development. Real secrets live in Vercel env vars.
# (.env* is gitignored — never commit filled-in values.)

# --- Auth.js (Google SSO, domain-locked to @intenthq.com) ---
AUTH_SECRET=                 # `npx auth secret`
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ADMIN_EMAILS=gareth.jones@intenthq.com   # comma-separated admin override list

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only: cron + admin imports

# --- Cron auth (Vercel sets this header on scheduled invocations) ---
CRON_SECRET=

# --- Vendor API credentials (server-only) ---
CURSOR_ADMIN_API_KEY=
ANTHROPIC_ADMIN_API_KEY=
OPENAI_ADMIN_API_KEY=
HIBOB_SERVICE_USER=
HIBOB_SERVICE_TOKEN=
